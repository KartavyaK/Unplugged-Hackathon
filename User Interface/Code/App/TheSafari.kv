<BookingLayout>:
    canvas.before:
        Color:
            rgba: BG_COLOR
        Rectangle:
            pos: self.pos
            size: self.size
    padding: 10
    spacing: 10
    orientation: "vertical"
    BoxLayout:
        padding: 10
        spacing: 10
        size_hint: 1, None
        height : "60dp"
        ForestButton:
            background_color: 0, 0, 0, 0
            background_normal: ''
            canvas.before:
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [self.height/2]
            text: "Safari"
            on_press: app.open_safari_popup()
        Label:
            text: "Safari App"
            font_size: "40sp"
            font_name: "fonts/WinterSong.ttf"
            size_hint: 8, 1
        ForestButton:
            background_color: 0, 0, 0, 0
            background_normal: ''
            canvas.before:
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [self.height/2]
            text: "Info"
            on_press: app.open_self_popup()

    GridLayout:
        size_hint: 1, 8
        cols: 2
        Label:
            text: "Time Slots"
            text_size: self.width, None
            halign: 'center'
            valign: 'middle'
            size_hint: 0.2, 0.2

        BoxLayout:
            size_hint: 1, 0.2
            spacing: 5
            padding: 5
            Label:
                halign: 'center'
                id: day0
            Label:
                halign: 'center'
                id: day1
            Label:
                halign: 'center'
                id: day2
            Label:
                halign: 'center'
                id: day3
            Label:
                halign: 'center'
                id: day4
            Label:
                halign: 'center'
                id: day5
            Label:
                halign: 'center'
                id: day6

        BoxLayout:
            orientation: "vertical"
            size_hint: 0.2, 1
            spacing: 5
            padding: 5
            Label:
                text: "09:00\n~\n12:00"
                text_size: self.width, None
                halign: 'center'
                valign: 'middle'
            Label:
                text: "14:00\n~\n17:00"
                text_size: self.width, None
                halign: 'center'
                valign: 'middle'
            Label:
                text: "18:00\n~\n21:00"
                text_size: self.width, None
                halign: 'center'
                valign: 'middle'

        BoxLayout:
            spacing: 5
            padding: 5

            BoxLayout:
                id: day0buttons
                orientation: "vertical"
                spacing: 100
                padding: 5
                ForestButton:
                    text: "60"
                    on_press: app.open_booking_popup(day0.text, '09:00:00', self.text)
                ForestButton:
                    text: "60"
                    on_press: app.open_booking_popup(day0.text, '14:00:00', self.text)
                ForestButton:
                    text: "60"
                    on_press: app.open_booking_popup(day0.text, '18:00:00', self.text)

            BoxLayout:
                id: day1buttons
                orientation: "vertical"
                spacing: 100
                padding: 5
                ForestButton:
                    text: "60"
                    on_press: app.open_booking_popup(day1.text, '09:00:00', self.text)
                ForestButton:
                    text: "60"
                    on_press: app.open_booking_popup(day1.text, '14:00:00', self.text)
                ForestButton:
                    text: "60"
                    on_press: app.open_booking_popup(day1.text, '18:00:00', self.text)

            BoxLayout:
                id: day2buttons
                orientation: "vertical"
                spacing: 100
                padding: 5
                ForestButton:
                    text: "60"
                    on_press: app.open_booking_popup(day2.text, '09:00:00', self.text)
                ForestButton:
                    text: "60"
                    on_press: app.open_booking_popup(day2.text, '14:00:00', self.text)
                ForestButton:
                    text: "60"
                    on_press: app.open_booking_popup(day2.text, '18:00:00', self.text)

            BoxLayout:
                id: day3buttons
                orientation: "vertical"
                spacing: 100
                padding: 5
                ForestButton:
                    text: "60"
                    on_press: app.open_booking_popup(day3.text, '09:00:00', self.text)
                ForestButton:
                    text: "60"
                    on_press: app.open_booking_popup(day3.text, '14:00:00', self.text)
                ForestButton:
                    text: "60"
                    on_press: app.open_booking_popup(day3.text, '18:00:00', self.text)

            BoxLayout:
                id: day4buttons
                orientation: "vertical"
                spacing: 100
                padding: 5
                ForestButton:
                    text: "60"
                    on_press: app.open_booking_popup(day4.text, '09:00:00', self.text)
                ForestButton:
                    text: "60"
                    on_press: app.open_booking_popup(day4.text, '14:00:00', self.text)
                ForestButton:
                    text: "60"
                    on_press: app.open_booking_popup(day4.text, '18:00:00', self.text)

            BoxLayout:
                id: day5buttons
                orientation: "vertical"
                spacing: 100
                padding: 5
                ForestButton:
                    text: "60"
                    on_press: app.open_booking_popup(day5.text, '09:00:00', self.text)
                ForestButton:
                    text: "60"
                    on_press: app.open_booking_popup(day5.text, '14:00:00', self.text)
                ForestButton:
                    text: "60"
                    on_press: app.open_booking_popup(day5.text, '18:00:00', self.text)

            BoxLayout:
                id: day6buttons
                orientation: "vertical"
                spacing: 100
                padding: 5
                ForestButton:
                    text: "60"
                    on_press: app.open_booking_popup(day6.text, '09:00:00', self.text)
                ForestButton:
                    text: "60"
                    on_press: app.open_booking_popup(day6.text, '14:00:00', self.text)
                ForestButton:
                    text: "60"
                    on_press: app.open_booking_popup(day6.text, '18:00:00', self.text)

    BoxLayout:
        padding: 10
        spacing: 20
        ForestButton:
            background_color: 0, 0, 0, 0
            background_normal: ''
            canvas.before:
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [self.height]
            text: "Home"
            on_press: app.root.show_user_home()
        ForestButton:
            background_color: 0, 0, 0, 0
            background_normal: ''
            canvas.before:
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [self.height]
            text: "Tickets"
            on_press: app.root.show_ticket()

<ForestButton@Button>:
    background_color: 0, 0, 0, 0
    background_normal: ''
    color: 1, 1, 1, 1

    canvas.before:
        Color:
            rgba: BTN_COLOR if self.state == 'normal' else BTN_COLOR_DOWN
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [20]

<ImageCircleButton@ButtonBehavior+Image>:
    size_hint: None, None
    size: "150dp", "150dp"
    allow_stretch: True
    keep_ratio: False

    canvas.before:
        StencilPush
        Ellipse:
            pos: self.pos
            size: self.size
        StencilUse

    canvas.after:
        StencilUnUse
        Ellipse:
            pos: self.pos
            size: self.size
        StencilPop